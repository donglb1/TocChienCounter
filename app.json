{
  "expo": {
    "name": "Tốc Chiến Counter",
    "slug": "toc-chien-counter",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e0e10"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.donglb.tocchiencounter",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Ứng dụng cần truy cập thư viện ảnh để đọc ảnh chụp màn hình team địch."
      }
    },
    "android": {
      "package": "com.donglb.tocchiencounter",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e0e10"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-image-picker",
      [
        "expo-media-library",
        {
          "photosPermission": "Ứng dụng cần đọc ảnh để lấy nhanh screenshot team địch bạn vừa chụp.",
          "savePhotosPermission": "Cho phép lưu ảnh.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#a855f7"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8d517eb3-e164-4804-8712-1cd5349a7c85"
      }
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/8d517eb3-e164-4804-8712-1cd5349a7c85"
    }
  }
}
